# Command history settings
HISTFILE=~/.histfile
HISTSIZE=2000
SAVEHIST=2000

# Require cd to change dirs
setopt noautocd

# Use Vim keys
bindkey -v

# Prompt setup
PROMPT='%c %# '

# Aliases
alias todo="vim ~/self/Todo.md"
alias please='sudo '
alias self="vim ~/self/index.md"
alias todo="vim ~/self/Todo.md"
alias focus="vim +Goyo"
